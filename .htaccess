Options -Indexes
DirectoryIndex index.html

# Correct MIME types
AddType text/css .css
AddType application/javascript .js

# Force HTTPS
RewriteEngine On

# Avoid intermittent DirectoryIndex failures on the Ladder route.
RewriteRule ^theladder/?$ /theladder/index.html [R=302,L]
RewriteRule ^theladder-products/?$ /theladder-products/index.html [R=302,L]

# Allow direct file access (assets, css, js, images)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# www to non-www
RewriteCond %{HTTP_HOST} ^www\.aesopacademy\.org [NC]
RewriteRule ^(.*)$ https://aesopacademy.org/$1 [L,R=301]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── COURSE REDIRECTS ──────────────────────────────────────
# /courses/{slug}/m{N} → electives hub (module-view.php no longer exists)
RewriteRule ^courses/([a-zA-Z0-9_-]+)/m([0-9]+)/?$ /ai-academy/modules/electives-hub.html?course=$1 [L,R=301]

# Old core module paths (module1-1 through module10-1) → AI Foundations
RewriteRule ^ai-academy/modules/module([0-9]+)-[0-9]+/(intro|basic|advanced)\.html$ /ai-academy/ [L,R=301]

# Custom 404
ErrorDocument 404 /index.html

# ─── CSS/JS CACHE CONTROL ─────────────────────────────────
# Forces browsers to revalidate CSS and JS on every visit.
# ETag lets the server say "nothing changed, use your copy"
# without re-sending the whole file — fast AND always fresh.
 
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|html|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header unset Expires
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  <FilesMatch "\.(css|js|html|json)$">
    ExpiresActive Off
  </FilesMatch>
</IfModule>
 
FileETag MTime Size
 
